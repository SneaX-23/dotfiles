{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",

    "transient_prompt": {
      "foreground": "#ffffff",
      "background": "transparent",
      "template": "\u279c "
    },

  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#757575",
          "style": "plain",
          "template": "\u250c",
          "type": "text"
        },
        {
          "foreground": "p:os",
          "style": "plain",
          "template": " {{.Icon}} ",
          "type": "os"
        },
        {
          "foreground": "#56B6C2",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": "{{ .Path }}",
          "type": "path"
        },
        {
          "foreground": "#D0666F",
          "options": {
            "branch_icon": "",
            "fetch_status": true
          },
          "style": "plain",
          "template": " <#5FAAE8>git:(</>{{ .HEAD }}{{ if .Working.Changed }} <#FFEB3B>{{ .Working.String }}</>{{ end }}<#5FAAE8>)</>{{ if or .Working.Changed .Staging.Changed }} <#FFEB3B>\u2717</>{{ end }}",
          "type": "git"
        }
      ],
      "type": "prompt",
      "newline": true
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#757575",
          "style": "plain",
          "template": "\u2514 ",
          "type": "text"
        },
        {
          "foreground_templates": ["{{ if gt .Code 0 }}#E06C75{{ end }}"],
          "foreground": "#98C379",
          "style": "plain",
          "template": "{{ if gt .Code 0 }}x{{ else }}\u279c{{ end }}",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
